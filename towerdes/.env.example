# ============================================================
# BẢO VỀ API KEYS - Environment Variables
# ============================================================
# HƯỚNG DẪN:
# 1. Local Development: Sao chép file này thành .env
# 2. Thay thế giá trị của các key
# 3. Thêm .env vào .gitignore để không commit lên git
# 4. Production (Cloudflare): Dùng `wrangler secret put` thay vì .env
# ============================================================

# Google Maps API Key
# Lấy từ: https://console.cloud.google.com/
# ⚠️ QUAN TRỌNG: Hạn chế API key bằng HTTP Referrers trên Google Cloud Console
GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Google Apps Script Auth URL
# Lấy từ: Google Apps Script → Deploy → New deployment
AUTH_URL=https://script.google.com/macros/s/YOUR_APPS_SCRIPT_ID/exec

# Xác thực người dùng
MY_KEY=your_secret_key_here

# ============================================================
# CLOUDFLARE WORKERS SECRETS (Production)
# ============================================================
# Để deploy trên Cloudflare, dùng command:
#   wrangler secret put GOOGLE_MAPS_KEY
#   wrangler secret put AUTH_URL
# 
# Không commit .env file lên GitHub!
# .gitignore đã chứa .env, .env.local
# ============================================================

# Cloudflare Worker URL (sau khi deploy)
# GOOGLE_MAPS_PROXY=https://tower-design-api.YOUR_USERNAME.workers.dev/api/maps/geocode
# AUTH_PROXY=https://tower-design-api.YOUR_USERNAME.workers.dev/api/auth/login
